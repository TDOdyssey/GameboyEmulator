X(0x00, 1, "NOP", /* TODO */ )
X(0x10, 1, "STOP", /* TODO */ )

// 8-bit load instructions
X(0x02, 2, "LD (BC), A",    write8(gb, gb->cpu.BC, gb->cpu.A); )
X(0x12, 2, "LD (DE), A",    write8(gb, gb->cpu.DE, gb->cpu.A); )
X(0x22, 2, "LD (HL+), A",   write8(gb, gb->cpu.HL++, gb->cpu.A); )
X(0x32, 2, "LD (HL-), A",   write8(gb, gb->cpu.HL--, gb->cpu.A); )

X(0x0a, 2, "LD A, (BC)",    gb->cpu.A = read8(gb, gb->cpu.BC); )
X(0x1a, 2, "LD A, (DE)",    gb->cpu.A = read8(gb, gb->cpu.DE); )
X(0x2a, 2, "LD A, (HL+)",   gb->cpu.A = read8(gb, gb->cpu.HL++); )
X(0x3a, 2, "LD A, (HL-)",   gb->cpu.A = read8(gb, gb->cpu.HL--); )

X(0x06, 2, "LD B, n",       gb->cpu.B = read_imm8(gb); )
X(0x16, 2, "LD D, n",       gb->cpu.D = read_imm8(gb); )
X(0x26, 2, "LD H, n",       gb->cpu.H = read_imm8(gb); )
X(0x36, 3, "LD (HL), n",    write8(gb, gb->cpu.HL, read_imm8(gb)); )
X(0x0e, 2, "LD C, n",       gb->cpu.C = read_imm8(gb); )
X(0x1e, 2, "LD E, n",       gb->cpu.E = read_imm8(gb); )
X(0x2e, 2, "LD L, n",       gb->cpu.L = read_imm8(gb); )
X(0x3e, 2, "LD A, n",       gb->cpu.A = read_imm8(gb); )

X(0x40, 1, "LD B, B",       gb->cpu.B = gb->cpu.B; )
X(0x41, 1, "LD B, C",       gb->cpu.B = gb->cpu.C; )
X(0x42, 1, "LD B, D",       gb->cpu.B = gb->cpu.D; )
X(0x43, 1, "LD B, E",       gb->cpu.B = gb->cpu.E; )
X(0x44, 1, "LD B, H",       gb->cpu.B = gb->cpu.H; )
X(0x45, 1, "LD B, L",       gb->cpu.B = gb->cpu.L; )
X(0x46, 2, "LD B, (HL)",    gb->cpu.B = read8(gb, gb->cpu.HL); )
X(0x47, 1, "LD B, A",       gb->cpu.B = gb->cpu.A; )

X(0x48, 1, "LD C, B",       gb->cpu.C = gb->cpu.B; )
X(0x49, 1, "LD C, C",       gb->cpu.C = gb->cpu.C; )
X(0x4A, 1, "LD C, D",       gb->cpu.C = gb->cpu.D; )
X(0x4B, 1, "LD C, E",       gb->cpu.C = gb->cpu.E; )
X(0x4C, 1, "LD C, H",       gb->cpu.C = gb->cpu.H; )
X(0x4D, 1, "LD C, L",       gb->cpu.C = gb->cpu.L; )
X(0x4E, 2, "LD C, (HL)",    gb->cpu.C = read8(gb, gb->cpu.HL); )
X(0x4F, 1, "LD C, A",       gb->cpu.C = gb->cpu.A; )

X(0x50, 1, "LD D, B",       gb->cpu.D = gb->cpu.B; )
X(0x51, 1, "LD D, C",       gb->cpu.D = gb->cpu.C; )
X(0x52, 1, "LD D, D",       gb->cpu.D = gb->cpu.D; )
X(0x53, 1, "LD D, E",       gb->cpu.D = gb->cpu.E; )
X(0x54, 1, "LD D, H",       gb->cpu.D = gb->cpu.H; )
X(0x55, 1, "LD D, L",       gb->cpu.D = gb->cpu.L; )
X(0x56, 2, "LD D, (HL)",    gb->cpu.D = read8(gb, gb->cpu.HL); )
X(0x57, 1, "LD D, A",       gb->cpu.D = gb->cpu.A; )

X(0x58, 1, "LD E, B",       gb->cpu.E = gb->cpu.B; )
X(0x59, 1, "LD E, C",       gb->cpu.E = gb->cpu.C; )
X(0x5A, 1, "LD E, D",       gb->cpu.E = gb->cpu.D; )
X(0x5B, 1, "LD E, E",       gb->cpu.E = gb->cpu.E; )
X(0x5C, 1, "LD E, H",       gb->cpu.E = gb->cpu.H; )
X(0x5D, 1, "LD E, L",       gb->cpu.E = gb->cpu.L; )
X(0x5E, 2, "LD E, (HL)",    gb->cpu.E = read8(gb, gb->cpu.HL); )
X(0x5F, 1, "LD E, A",       gb->cpu.E = gb->cpu.A; )

X(0x60, 1, "LD H, B",       gb->cpu.H = gb->cpu.B; )
X(0x61, 1, "LD H, C",       gb->cpu.H = gb->cpu.C; )
X(0x62, 1, "LD H, D",       gb->cpu.H = gb->cpu.D; )
X(0x63, 1, "LD H, E",       gb->cpu.H = gb->cpu.E; )
X(0x64, 1, "LD H, H",       gb->cpu.H = gb->cpu.H; )
X(0x65, 1, "LD H, L",       gb->cpu.H = gb->cpu.L; )
X(0x66, 2, "LD H, (HL)",    gb->cpu.H = read8(gb, gb->cpu.HL); )
X(0x67, 1, "LD H, A",       gb->cpu.H = gb->cpu.A )

X(0x68, 1, "LD L, B",       gb->cpu.L = gb->cpu.B; )
X(0x69, 1, "LD L, C",       gb->cpu.L = gb->cpu.C; )
X(0x6A, 1, "LD L, D",       gb->cpu.L = gb->cpu.D; )
X(0x6B, 1, "LD L, E",       gb->cpu.L = gb->cpu.E; )
X(0x6C, 1, "LD L, H",       gb->cpu.L = gb->cpu.H; )
X(0x6D, 1, "LD L, L",       gb->cpu.L = gb->cpu.L; )
X(0x6E, 2, "LD L, (HL)",    gb->cpu.L = read8(gb, gb->cpu.HL); )
X(0x6F, 1, "LD L, A",       gb->cpu.L = gb->cpu.A; )

X(0x70, 2, "LD (HL), B", write8(gb, gb->cpu.HL, gb->cpu.B); )
X(0x71, 2, "LD (HL), C", write8(gb, gb->cpu.HL, gb->cpu.C); )
X(0x72, 2, "LD (HL), D", write8(gb, gb->cpu.HL, gb->cpu.D); )
X(0x73, 2, "LD (HL), E", write8(gb, gb->cpu.HL, gb->cpu.E); )
X(0x74, 2, "LD (HL), H", write8(gb, gb->cpu.HL, gb->cpu.H); )
X(0x75, 2, "LD (HL), L", write8(gb, gb->cpu.HL, gb->cpu.L); )
X(0x76, 1, "HALT", /* TODO */ )
X(0x77, 2, "LD (HL), L", write8(gb, gb->cpu.HL, gb->cpu.A); )

X(0x78, 1, "LD A, B",       gb->cpu.A = gb->cpu.B; )
X(0x79, 1, "LD A, C",       gb->cpu.A = gb->cpu.C; )
X(0x7A, 1, "LD A, D",       gb->cpu.A = gb->cpu.D; )
X(0x7B, 1, "LD A, E",       gb->cpu.A = gb->cpu.E; )
X(0x7C, 1, "LD A, H",       gb->cpu.A = gb->cpu.H; )
X(0x7D, 1, "LD A, L",       gb->cpu.A = gb->cpu.L; )
X(0x7E, 2, "LD A, (HL)",    gb->cpu.A = read8(gb, gb->cpu.HL); )
X(0x7F, 1, "LD A, A",       gb->cpu.A = gb->cpu.A; )

X(0xe0, 3, "LDH (n), A", write8(gb, 0xFF00 | read_imm8(gb), gb->cpu.A); )
X(0xf0, 3, "LDH A, (n)", gb->cpu.A = read8(gb, 0xFF00 | read_imm8(gb)); )

X(0xe2, 2, "LDH (C), A", write8(gb, 0xFF00 | gb->cpu.C, gb->cpu.A); )
X(0xf2, 2, "LDH A, (C)", gb->cpu.A = read8(gb, 0xFF00 | gb->cpu.C); )

X(0xea, 4, "LD (nn), A", write8(gb, read_imm16(gb), gb->cpu.A); )
X(0xfa, 4, "LD A, (nn)", gb->cpu.A = read8(gb, read_imm16(gb)); )

// 16 bit loads
X(0x01, 3, "LD BC, nn", gb->cpu.BC = read_imm16(gb); )
X(0x11, 3, "LD DE, nn", gb->cpu.DE = read_imm16(gb); )
X(0x21, 3, "LD HL, nn", gb->cpu.HL = read_imm16(gb); )
X(0x31, 3, "LD SP, nn", gb->cpu.SP = read_imm16(gb); )

X(0xc1, 3, "POP BC", gb->cpu.BC = pop(gb); )
X(0xd1, 3, "POP DE", gb->cpu.DE = pop(gb); )
X(0xe1, 3, "POP HL", gb->cpu.HL = pop(gb); )
X(0xf1, 3, "POP AF", gb->cpu.AF = pop(gb); )

X(0xc5, 4, "PUSH BC", push(gb, gb->cpu.BC); )
X(0xd5, 4, "PUSH DE", push(gb, gb->cpu.DE); )
X(0xe5, 4, "PUSH HL", push(gb, gb->cpu.HL); )
X(0xf5, 4, "PUSH AF", push(gb, gb->cpu.AF); )

X(0x08, 5, "LD (nn), SP", \
    uint16_t nn = read_imm16(gb);
    write8(gb, nn, gb->cpu.SP & 0x00FF); \
    write8(gb, nn + 1, gb->cpu.SP >> 8); \
)
X(0xf8, 3, "LD HL, SP+e", \
    int8_t e = (int8_t)read_imm8(gb); \
    gb->cpu.HL = gb->cpu.SP + e; \
    set_flag(gb, z | n, 0); \
    set_flag(gb, h, (gb->cpu.SP & 0xF) + (e & 0xF) > 0xF); \
    set_flag(gb, c, (gb->cpu.SP & 0xFF) + (e & 0xFF) > 0xFF); \
)

X(0xf9, 2, "LD SP, HL", gb->cpu.SP = gb->cpu.HL; )

// 8-bit arithmetic/logical

// INC
X(0x04, 1, "INC B",     INC_R(gb, &gb->cpu.D); )
X(0x14, 1, "INC D",     INC_R(gb, &gb->cpu.D); )
X(0x24, 1, "INC H",     INC_R(gb, &gb->cpu.H); )
X(0x34, 3, "INC (HL)", uint8_t val = read8(gb, gb->cpu.HL); INC_R(gb, &val); write8(gb, gb->cpu.HL, val); )
X(0x0c, 1, "INC C",     INC_R(gb, &gb->cpu.C); )
X(0x1c, 1, "INC E",     INC_R(gb, &gb->cpu.E); )
X(0x2c, 1, "INC L",     INC_R(gb, &gb->cpu.L); )
X(0x3c, 1, "INC A",     INC_R(gb, &gb->cpu.A); )

// DEC 
X(0x05, 1, "DEC B", DEC_R(gb, &gb->cpu.B); )
X(0x15, 1, "DEC D", DEC_R(gb, &gb->cpu.D); )
X(0x25, 1, "DEC H", DEC_R(gb, &gb->cpu.H); )
X(0x35, 3, "DEC (HL)", uint8_t val = read8(gb, gb->cpu.HL); DEC_R(gb, &val); write8(gb, gb->cpu.HL, val); )
X(0x0d, 1, "DEC C", DEC_R(gb, &gb->cpu.C); )
X(0x1d, 1, "DEC E", DEC_R(gb, &gb->cpu.E); )
X(0x2d, 1, "DEC L", DEC_R(gb, &gb->cpu.L); )
X(0x3d, 1, "DEC A", DEC_R(gb, &gb->cpu.A); )

X(0x27, 1, "DAA", /* TODO */ )
X(0x37, 1, "SCF", set_flag(gb, n, false); set_flag(gb, h, false); set_flag(gb, c, true); )

X(0x2f, 1, "CPL", gb->cpu.A = ~gb->cpu.A; set_flag(gb, n, 1); set_flag(gb, h, 1); )
X(0x3f, 1, "CCF", set_flag(gb, c, !(get_flag(gb, c))); set_flag(gb, n, false); set_flag(gb, h, false); )

// ADD
X(0x80, 1, "ADD B", ADD_R(gb, gb->cpu.B, false); )
X(0x81, 1, "ADD C", ADD_R(gb, gb->cpu.C, false); )
X(0x82, 1, "ADD D", ADD_R(gb, gb->cpu.D, false); )
X(0x83, 1, "ADD E", ADD_R(gb, gb->cpu.E, false); )
X(0x84, 1, "ADD H", ADD_R(gb, gb->cpu.H, false); )
X(0x85, 1, "ADD L", ADD_R(gb, gb->cpu.L, false); )
X(0x86, 2, "ADD (HL)", ADD_R(gb, read8(gb, gb->cpu.HL), false); )
X(0x87, 1, "ADD A", ADD_R(gb, gb->cpu.A, false); )

X(0xc6, 2, "ADD n", ADD_R(gb, read_imm8(gb), false); )

// ADC
X(0x88, 1, "ADC B", ADD_R(gb, gb->cpu.B, true); )
X(0x89, 1, "ADC C", ADD_R(gb, gb->cpu.C, true); )
X(0x8a, 1, "ADC D", ADD_R(gb, gb->cpu.D, true); )
X(0x8b, 1, "ADC E", ADD_R(gb, gb->cpu.E, true); )
X(0x8c, 1, "ADC H", ADD_R(gb, gb->cpu.H, true); )
X(0x8d, 1, "ADC L", ADD_R(gb, gb->cpu.L, true); )
X(0x8e, 2, "ADD (HL)", ADD_R(gb, read8(gb, gb->cpu.HL), true); )
X(0x8f, 1, "ADC A", ADD_R(gb, gb->cpu.A, true); )

X(0xce, 2, "ADC n", ADD_R(gb, read_imm8(gb), true); )

// SUB
X(0x90, 1, "SUB B", SUB_R(gb, gb->cpu.B, false); )
X(0x91, 1, "SUB C", SUB_R(gb, gb->cpu.C, false); )
X(0x92, 1, "SUB D", SUB_R(gb, gb->cpu.D, false); )
X(0x93, 1, "SUB E", SUB_R(gb, gb->cpu.E, false); )
X(0x94, 1, "SUB H", SUB_R(gb, gb->cpu.H, false); )
X(0x95, 1, "SUB L", SUB_R(gb, gb->cpu.L, false); )
X(0x96, 2, "SUB (HL)", SUB_R(gb, read8(gb, gb->cpu.HL), false); )
X(0x97, 1, "SUB A", SUB_R(gb, gb->cpu.A, false); )

X(0xd6, 2, "SUB n", SUB_R(gb, read_imm8(gb), false); )

// SBC
X(0x98, 1, "SBC B", SUB_R(gb, gb->cpu.B, true); )
X(0x99, 1, "SBC C", SUB_R(gb, gb->cpu.C, true); )
X(0x9a, 1, "SBC D", SUB_R(gb, gb->cpu.D, true); )
X(0x9b, 1, "SBC E", SUB_R(gb, gb->cpu.E, true); )
X(0x9c, 1, "SBC H", SUB_R(gb, gb->cpu.H, true); )
X(0x9d, 1, "SBC L", SUB_R(gb, gb->cpu.L, true); )
X(0x9e, 2, "SBC (HL)", SUB_R(gb, read8(gb, gb->cpu.HL), true); )
X(0x9f, 1, "SBC A", SUB_R(gb, gb->cpu.A, true); )

X(0xde, 2, "SBC n", SUB_R(gb, read_imm8(gb), true); )

// AND
X(0xa0, 1, "AND B", gb->cpu.A &= gb->cpu.B; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n, 0); set_flag(gb, h, 1); set_flag(gb, c, 0); )
X(0xa1, 1, "AND C", gb->cpu.A &= gb->cpu.C; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n, 0); set_flag(gb, h, 1); set_flag(gb, c, 0); )
X(0xa2, 1, "AND D", gb->cpu.A &= gb->cpu.D; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n, 0); set_flag(gb, h, 1); set_flag(gb, c, 0); )
X(0xa3, 1, "AND E", gb->cpu.A &= gb->cpu.E; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n, 0); set_flag(gb, h, 1); set_flag(gb, c, 0); )
X(0xa4, 1, "AND H", gb->cpu.A &= gb->cpu.H; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n, 0); set_flag(gb, h, 1); set_flag(gb, c, 0); )
X(0xa5, 1, "AND L", gb->cpu.A &= gb->cpu.L; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n, 0); set_flag(gb, h, 1); set_flag(gb, c, 0); )
X(0xa6, 2, "AND (HL)", gb->cpu.A &= read8(gb, gb->cpu.HL); set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n, 0); set_flag(gb, h, 1); set_flag(gb, c, 0); )
X(0xa7, 1, "AND A", gb->cpu.A &= gb->cpu.A; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n, 0); set_flag(gb, h, 1); set_flag(gb, c, 0); )

X(0xe6, 2, "AND n", gb->cpu.A &= read_imm8(gb); )

// XOR
X(0xa8, 1, "XOR B", gb->cpu.A ^= gb->cpu.B; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n | h | c, 0); )
X(0xa9, 1, "XOR C", gb->cpu.A ^= gb->cpu.C; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n | h | c, 0); )
X(0xaa, 1, "XOR D", gb->cpu.A ^= gb->cpu.D; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n | h | c, 0); )
X(0xab, 1, "XOR E", gb->cpu.A ^= gb->cpu.E; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n | h | c, 0); )
X(0xac, 1, "XOR H", gb->cpu.A ^= gb->cpu.H; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n | h | c, 0); )
X(0xad, 1, "XOR L", gb->cpu.A ^= gb->cpu.L; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n | h | c, 0); )
X(0xae, 2, "XOR (HL)", gb->cpu.A ^= read8(gb, gb->cpu.HL); set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n | h | c, 0); )
X(0xaf, 1, "XOR A", gb->cpu.A ^= gb->cpu.A; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n | h | c, 0); )

X(0xee, 2, "XOR n", gb->cpu.A &= read_imm8(gb); )

// OR
X(0xb0, 1, "OR B", gb->cpu.A |= gb->cpu.B; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n | h | c, 0); )
X(0xb1, 1, "OR C", gb->cpu.A |= gb->cpu.C; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n | h | c, 0); )
X(0xb2, 1, "OR D", gb->cpu.A |= gb->cpu.D; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n | h | c, 0); )
X(0xb3, 1, "OR E", gb->cpu.A |= gb->cpu.E; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n | h | c, 0); )
X(0xb4, 1, "OR H", gb->cpu.A |= gb->cpu.H; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n | h | c, 0); )
X(0xb5, 1, "OR L", gb->cpu.A |= gb->cpu.L; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n | h | c, 0); )
X(0xb6, 2, "OR (HL)", gb->cpu.A |= read8(gb, gb->cpu.HL); set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n | h | c, 0); )
X(0xb7, 1, "OR A", gb->cpu.A |= gb->cpu.A; set_flag(gb, z, gb->cpu.A == 0); set_flag(gb, n | h | c, 0); )

X(0xf6, 2, "OR n", gb->cpu.A |= read_imm8(gb); )

// CP
X(0xb8, 1, "CP B", CP_R(gb, gb->cpu.B); )
X(0xb9, 1, "CP C", CP_R(gb, gb->cpu.C); )
X(0xba, 1, "CP D", CP_R(gb, gb->cpu.D); )
X(0xbb, 1, "CP E", CP_R(gb, gb->cpu.E); )
X(0xbc, 1, "CP H", CP_R(gb, gb->cpu.H); )
X(0xbd, 1, "CP L", CP_R(gb, gb->cpu.L); )
X(0xbe, 2, "CP (HL)", CP_R(gb, read8(gb, gb->cpu.HL)); )
X(0xbf, 1, "CP A", CP_R(gb, gb->cpu.A); )

X(0xfe, 2, "CP n", CP_R(gb, read_imm8(gb)); )

// 16 bit arithmetic
X(0x03, 2, "INC BC", gb->cpu.BC++; )
X(0x13, 2, "INC DE", gb->cpu.DE++; )
X(0x23, 2, "INC HL", gb->cpu.HL++; )
X(0x33, 2, "INC SP", gb->cpu.SP++; )

X(0x09, 2, "ADD HL,BC", ADD_HL(gb, gb->cpu.BC); )
X(0x19, 2, "ADD HL,DE", ADD_HL(gb, gb->cpu.DE); )
X(0x29, 2, "ADD HL,HL", ADD_HL(gb, gb->cpu.HL); )
X(0x39, 2, "ADD HL,SP", ADD_HL(gb, gb->cpu.SP); )

X(0x0b, 2, "DEC BC", gb->cpu.BC--; )
X(0x1b, 2, "DEC DE", gb->cpu.DE--; )
X(0x2b, 2, "DEC HL", gb->cpu.HL--; )
X(0x3b, 2, "DEC SP", gb->cpu.SP--; )

X(0xe8, 4, "ADD SP, e",  \
int8_t e = (int8_t)read_imm8(gb); \
set_flag(gb, z, false); \
set_flag(gb, n, false); \
set_flag(gb, h, (gb->cpu.SP & 0xF) + (e & 0xF) > 0xF); \
set_flag(gb, c, (gb->cpu.SP & 0xFF) + (e & 0xFF) > 0xFF); \
gb->cpu.SP = gb->cpu.SP + e; \
)

// Control flow

// Relative jump
X(0x20, 2, "JR NZ, e", int8_t e = (int8_t)read_imm8(gb); if(!get_flag(gb, z)) { gb->cpu.PC += e; gb->cycles = 3; } )
X(0x30, 2, "JR NC, e", int8_t e = (int8_t)read_imm8(gb); if(!get_flag(gb, c)) { gb->cpu.PC += e; gb->cycles = 3; } )
X(0x18, 3, "JR e", int8_t e = (int8_t)read_imm8(gb); gb->cpu.PC += e; )
X(0x28, 2, "JR Z, e", int8_t e = (int8_t)read_imm8(gb); if(get_flag(gb, z)) { gb->cpu.PC += e; gb->cycles = 3; } )
X(0x38, 2, "JR C, e", int8_t e = (int8_t)read_imm8(gb); if(get_flag(gb, c)) { gb->cpu.PC += e; gb->cycles = 3; } )

// Return from function
X(0xc0, 2, "RET NZ", if(!get_flag(gb, z)) { gb->cpu.PC = pop(gb); gb->cycles = 5; } )
X(0xd0, 2, "RET NC", if(!get_flag(gb, c)) { gb->cpu.PC = pop(gb); gb->cycles = 5; } )
X(0xc8, 2, "RET Z", if(get_flag(gb, c)) { gb->cpu.PC = pop(gb); gb->cycles = 5; } )
X(0xd8, 2, "RET C", if(get_flag(gb, c)) { gb->cpu.PC = pop(gb); gb->cycles = 5; } )
X(0xc9, 4, "RET", gb->cpu.PC = pop(gb); )
X(0xd9, 4, "RETI", gb->cpu.PC = pop(gb); gb->ime = 1; )

// Jump
X(0xc2, 3, "JP NZ, nn", uint16_t addr = read_imm16(gb); if(!get_flag(gb, z)) {gb->cpu.PC = addr; gb->cycles = 4;} )
X(0xd2, 3, "JP NC, nn", uint16_t addr = read_imm16(gb); if(!get_flag(gb, c)) {gb->cpu.PC = addr; gb->cycles = 4;} )
X(0xca, 3, "JP Z, nn",  uint16_t addr = read_imm16(gb); if(get_flag(gb, z)) {gb->cpu.PC = addr; gb->cycles = 4;} )
X(0xda, 3, "JP C, nn",  uint16_t addr = read_imm16(gb); if(get_flag(gb, c)) {gb->cpu.PC = addr; gb->cycles = 4;} )
X(0xc3, 4, "JP nn",     gb->cpu.PC = read_imm16(gb); )
X(0xe9, 1, "JP HL",     gb->cpu.PC = gb->cpu.HL; )

// Call
X(0xc4, 3, "CALL NZ, nn",   uint16_t addr = read_imm16(gb); if(!get_flag(gb, z)) { push(gb, gb->cpu.PC); gb->cpu.PC = addr; gb->cycles = 6; } )
X(0xd4, 3, "CALL NC, nn",   uint16_t addr = read_imm16(gb); if(!get_flag(gb, c)) { push(gb, gb->cpu.PC); gb->cpu.PC = addr; gb->cycles = 6; } )
X(0xcc, 3, "CALL Z, nn",    uint16_t addr = read_imm16(gb); if(get_flag(gb, z)) { push(gb, gb->cpu.PC); gb->cpu.PC = addr; gb->cycles = 6; } )
X(0xdc, 3, "CALL C, nn",    uint16_t addr = read_imm16(gb); if(get_flag(gb, c)) { push(gb, gb->cpu.PC); gb->cpu.PC = addr; gb->cycles = 6; } )
X(0xcd, 6, "CALL nn",       uint16_t addr = read_imm16(gb); push(gb, gb->cpu.PC); gb->cpu.PC = addr; )


// Restart
X(0xc7, 4, "RST 0x00", push(gb, gb->cpu.PC); gb->cpu.PC = 0x0000; )
X(0xd7, 4, "RST 0x10", push(gb, gb->cpu.PC); gb->cpu.PC = 0x0010; )
X(0xe7, 4, "RST 0x20", push(gb, gb->cpu.PC); gb->cpu.PC = 0x0020; )
X(0xf7, 4, "RST 0x30", push(gb, gb->cpu.PC); gb->cpu.PC = 0x0030; )

X(0xcf, 4, "RST 0x08", push(gb, gb->cpu.PC); gb->cpu.PC = 0x0008; )
X(0xdf, 4, "RST 0x18", push(gb, gb->cpu.PC); gb->cpu.PC = 0x0018; )
X(0xef, 4, "RST 0x28", push(gb, gb->cpu.PC); gb->cpu.PC = 0x0028; )
X(0xff, 4, "RST 0x38", push(gb, gb->cpu.PC); gb->cpu.PC = 0x0038; )

// Misc
X(0xf3, 1, "DI", gb->ime = false; gb->ime_delay = 0; )
X(0xfb, 1, "EI", gb->ime_delay = 2; )


// CB-Prefix
X(0xcb, 1, "CB", execute_cb_op(gb, read_imm8(gb)); )

